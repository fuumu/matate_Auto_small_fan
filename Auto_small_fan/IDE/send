/*
  学習リモコン ── 送信側スケッチ
  ----------------------------------------------------
  ボード      : Arduino UNO R4 WiFi
  ライブラリ  : IRremote 4.x 以降（ライブラリマネージャで "IRremote" を検索しインストール）
  送信ピン    : D3  →  R1(470Ω)  →  トランジスタのベース
                5V  →  赤外線LED  →  R2(33〜47Ω)  →  コレクタ
                エミッタ  →  GND

  使い方の順番（おすすめ）:
    STEP 1) まず loop() のテスト送信で、手元の受信機が正しいコードを
            受け取れるか確認する（回路・ライブラリの動作確認）。
    STEP 2) 受信側で取得した protocol / address / command を
            sendStoredCode() に書き込み、自分の機器を操作する。
  ----------------------------------------------------
*/

#define IR_SEND_PIN 3        // 送信ピン。必ず #include より前に定義する
#include <IRremote.hpp>      // 4.x 系は .hpp をインクルード（スケッチ内で1回だけ）

void setup() {
  Serial.begin(115200);
  while (!Serial && millis() < 3000) {
    ; // R4 はSerial接続を少し待つ（無くても可。最大3秒で抜ける）
  }

  IrSender.begin(IR_SEND_PIN);   // 送信開始。D3 を出力に設定する
  Serial.println(F("IR sender ready (pin D3). Sending NEC test code..."));
}

void loop() {
  // ===== STEP 1: テスト送信 ============================
  // NEC プロトコルで address=0x0102, command=0x34 を送る。
  // 受信機側の表示が毎回同じ値になれば、回路もライブラリも正常。
  uint16_t address = 0x0102;
  uint8_t  command = 0x34;
  uint8_t  repeats = 0;        // 連続送信回数（リピート）。0 で1回だけ

  Serial.print(F("Send NEC  addr=0x"));
  Serial.print(address, HEX);
  Serial.print(F("  cmd=0x"));
  Serial.println(command, HEX);

  IrSender.sendNEC(address, command, repeats);

  delay(2000);                 // 2秒ごとに送信

  // ===== STEP 2: 自分が記録したコードを送る ============
  // 動作確認できたら上のテスト送信をコメントアウトし、
  // 下を有効にして使う。受信側で得た値を書き込むこと。
  //
  // sendStoredCode();
  // delay(2000);
}


// ----------------------------------------------------
// 受信側で記録したコードを送信する例。
// 受信スケッチの IrReceiver.printIRResultShort() などで表示された
// Protocol / Address / Command の値をここに書き写す。
// ----------------------------------------------------
void sendStoredCode() {
  // 例1) NEC の機器（多くの国内家電・汎用リモコン）
  IrSender.sendNEC(0x0102, 0x34, 0);

  // 例2) Sony（SIRC）の機器は送信時にビット数の指定が必要
  //      （12 / 15 / 20 bit のいずれか。受信時の bits を見て合わせる）
  // IrSender.sendSony(0x1, 0x12, 0, 12);

  // 例3) Panasonic（Kaseikyo系）
  // IrSender.sendPanasonic(0x4004, 0x0100BCBD, 0);

  // 例4) 上記以外・プロトコル不明（UNKNOWN）の場合は RAW で送る。
  //      受信側 ReceiveDump.ino が出力する rawData[] 配列をそのまま貼り付ける。
  //      （配列名・長さ・キャリア周波数38kHzは受信側の出力に合わせる）
  // const uint16_t rawData[] = { 9000,4500, 560,560, 560,1690, /* ... */ };
  // IrSender.sendRaw(rawData, sizeof(rawData) / sizeof(rawData[0]), 38);
}

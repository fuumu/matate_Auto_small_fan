/*
  学習リモコン ── 複数スロット＋RAW(生データ)対応版
  ============================================================
  ボード      : Arduino UNO R4 WiFi
  ライブラリ  : IRremote 4.x 以降

  ■ できること
    ・複数の信号を「スロット」に記録できる（NUM_SLOTS 個）
    ・テレビ等の通常コード(NEC等)は自動再現、エアコン等の長い/未知の信号は
      生データ(RAW)として丸ごと記録・再生する
    ・エアコンの「風量・弱／中／強」などは、それぞれの状態をリモコンで作って
      別スロットに記録 → 送信ボタンで再現する

  ■ ボタン操作
    選択ボタン(D4): 記録/送信する対象スロットを切り替える（0,1,2... と循環）
    記録ボタン(D5): 現在のスロットに、次に受信した信号を記録する
    送信ボタン(D6): 現在のスロットの信号を送信する
    （状態はシリアルモニタ 115200bps に表示）

  ■ 配線
    D3 : 赤外線LED送信  … R1→トランジスタのベース / 5V→LED→R2→コレクタ
    D2 : 赤外線受信モジュール OUT（環境に合わせて変更）
    D4,D5,D6 : 各ボタン … 片側をピン、もう片側をGND（内部プルアップ使用）
  ============================================================
*/

#define IR_SEND_PIN        3
#define IR_RECEIVE_PIN     2
#define BUTTON_SELECT_PIN  4
#define BUTTON_RECORD_PIN  5
#define BUTTON_SEND_PIN    6

// --- エアコン等の長い信号に対応するための設定（#include より前に置く）---
#define RAW_BUFFER_LENGTH  750    // 受信バッファを拡大（標準は約100。R4はRAMに余裕あり）
//#define RECORD_GAP_MICROS 12000 // 一部のエアコン(LG等)で1フレームが途中で切れる場合に有効化

#include <IRremote.hpp>

#define NUM_SLOTS 5               // 記録できる信号の数（RAMに応じて増減可）

// 1スロット分の保存領域（公式ReceiveAndSendと同じ構造）
struct StoredCode {
  IRData   data;                       // デコード済みコード用
  uint8_t  rawCode[RAW_BUFFER_LENGTH]; // 生データ(RAW)用
  uint16_t rawLength;                  // 生データの長さ
  bool     used;                       // 記録済みか
};
StoredCode slots[NUM_SLOTS];

uint8_t activeSlot   = 0;        // 現在選択中のスロット
bool    armRecording = false;    // 記録待ちか

// ---- ボタン（チャタリング除去つきの押下検出） ----
struct Button { uint8_t pin; bool lastReading; bool stableState; unsigned long lastChange; };
Button btnSelect = { BUTTON_SELECT_PIN, HIGH, HIGH, 0 };
Button btnRecord = { BUTTON_RECORD_PIN, HIGH, HIGH, 0 };
Button btnSend   = { BUTTON_SEND_PIN,   HIGH, HIGH, 0 };

bool wasPressed(Button &b) {
  bool reading = digitalRead(b.pin);
  if (reading != b.lastReading) { b.lastChange = millis(); b.lastReading = reading; }
  if (millis() - b.lastChange > 30) {
    if (reading != b.stableState) {
      b.stableState = reading;
      if (b.stableState == LOW) return true;   // 押した瞬間
    }
  }
  return false;
}

// 受信した信号を指定スロットに記録。成功したら true
bool storeCode(StoredCode *dst) {
  // 押しっぱなしのリピート信号は無視
  if (IrReceiver.decodedIRData.flags & IRDATA_FLAGS_IS_REPEAT) return false;

  if (IrReceiver.decodedIRData.protocol == UNKNOWN) {
    // 未知・長い信号（エアコン等）→ 生データで丸ごと保存
    // バッファ溢れ（信号が長すぎ）なら記録しない
    if (IrReceiver.decodedIRData.flags & IRDATA_FLAGS_WAS_OVERFLOW) {
      Serial.println(F("  ※バッファ不足！ RAW_BUFFER_LENGTH を大きくしてください"));
      return false;
    }
    // compensateAndStoreIRResultInArray() は戻り値なし(void)。
    // 長さは別途 rawlen-1（先頭のギャップを除いた数）から取得する。
    IrReceiver.compensateAndStoreIRResultInArray(dst->rawCode);
    dst->rawLength     = IrReceiver.decodedIRData.rawlen - 1;
    dst->data.protocol = UNKNOWN;
    Serial.print(F("  RAWで記録: "));
    Serial.print(dst->rawLength);
    Serial.println(F(" 個の時間データ"));
  } else {
    // デコードできた通常コード → IRDataとして保存
    IrReceiver.decodedIRData.flags = 0;
    dst->data = IrReceiver.decodedIRData;
    Serial.print(F("  記録: "));
    IrReceiver.printIRResultShort(&Serial);
  }
  dst->used = true;
  return true;
}

// 指定スロットの信号を送信
void sendCode(StoredCode *src) {
  if (!src->used) { Serial.println(F("  このスロットは空です")); return; }

  if (src->data.protocol == UNKNOWN) {
    IrSender.sendRaw(src->rawCode, src->rawLength, 38);   // 38kHzで生データ送信
    Serial.println(F("  RAW送信"));
  } else {
    IrSender.write(&src->data);                            // 通常コードを再現して送信
    Serial.print(F("  送信: "));
    printIRResultShort(&Serial, &src->data);
  }
  IrReceiver.restartAfterSend();   // 送信で乱れた受信タイマを元に戻す
}

void printActiveSlot() {
  Serial.print(F("▼ 選択スロット = "));
  Serial.print(activeSlot);
  Serial.println(slots[activeSlot].used ? F("（記録あり）") : F("（空）"));
}

void setup() {
  Serial.begin(115200);
  while (!Serial && millis() < 3000) { ; }

  pinMode(BUTTON_SELECT_PIN, INPUT_PULLUP);
  pinMode(BUTTON_RECORD_PIN, INPUT_PULLUP);
  pinMode(BUTTON_SEND_PIN,   INPUT_PULLUP);

  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);
  IrSender.begin(IR_SEND_PIN);

  Serial.println(F("学習リモコン（複数スロット版）準備完了"));
  Serial.println(F("選択(D4) / 記録(D5) / 送信(D6)"));
  printActiveSlot();
}

void loop() {
  // 選択：スロットを切り替え
  if (wasPressed(btnSelect)) {
    activeSlot = (activeSlot + 1) % NUM_SLOTS;
    printActiveSlot();
  }

  // 記録：次の受信信号を現在のスロットへ
  if (wasPressed(btnRecord)) {
    armRecording = true;
    Serial.print(F("[記録待ち] スロット"));
    Serial.print(activeSlot);
    Serial.println(F(" にリモコン信号を覚えさせます。リモコンのボタンを押してください..."));
  }

  // 受信処理（常に監視）
  if (IrReceiver.decode()) {
    if (armRecording) {
      if (storeCode(&slots[activeSlot])) {
        armRecording = false;
        Serial.print(F("→ スロット"));
        Serial.print(activeSlot);
        Serial.println(F(" に保存しました"));
      }
    }
    IrReceiver.resume();
  }

  // 送信：現在のスロットを送る
  if (wasPressed(btnSend)) {
    Serial.print(F("[送信] スロット"));
    Serial.println(activeSlot);
    sendCode(&slots[activeSlot]);
  }
}

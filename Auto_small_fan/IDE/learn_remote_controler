/*
  学習リモコン ── 受信ボタン＋送信ボタン版
  ============================================================
  ボード      : Arduino UNO R4 WiFi
  ライブラリ  : IRremote 4.x 以降（ライブラリマネージャで "IRremote"）

  ■ 動作
    ・受信ボタン(D4)を押す → 受信待ちになる
       → リモコンのボタンを赤外線受信モジュールに向けて押すとコマンドを記録
    ・送信ボタン(D5)を押す → 記録したコマンドを赤外線LEDから送信

  ■ 配線（ピン番号は環境に合わせて変更可）
    D3  : 赤外線LED 送信   … R1(470Ω)→トランジスタのベース
                             5V→IR LED→R2(33〜47Ω)→コレクタ, エミッタ→GND
    D2  : 赤外線受信モジュールの OUT（※受信側の配線に合わせて変更）
    D4  : 受信ボタン        … ボタンの片側をD4、もう片側をGNDへ
    D5  : 送信ボタン        … ボタンの片側をD5、もう片側をGNDへ
          （ボタンは内部プルアップを使うので外付け抵抗は不要。押すとLOW）
  ============================================================
*/

#define IR_SEND_PIN          3   // 赤外線LED送信ピン（#include より前に定義）
#define IR_RECEIVE_PIN       2   // 赤外線受信モジュールのOUT（環境に合わせて変更）
#define BUTTON_RECEIVE_PIN   4   // 受信ボタン
#define BUTTON_SEND_PIN      5   // 送信ボタン

#include <IRremote.hpp>          // 4.x 系は .hpp（スケッチ内で1回だけインクルード）

IRData storedIRData;             // 記録したコマンドの保存先
bool    hasStoredCode = false;   // 記録済みかどうか
bool    armRecording  = false;   // 受信ボタンが押されて「記録待ち」状態か

// ---- ボタン用（チャタリング除去つきの押下検出） ----
struct Button {
  uint8_t pin;
  bool    lastReading;
  bool    stableState;
  unsigned long lastChange;
};
Button btnReceive = { BUTTON_RECEIVE_PIN, HIGH, HIGH, 0 };
Button btnSend    = { BUTTON_SEND_PIN,    HIGH, HIGH, 0 };

// 押された瞬間に1回だけ true を返す（プルアップなので押下＝LOW）
bool wasPressed(Button &b) {
  bool reading = digitalRead(b.pin);
  if (reading != b.lastReading) {
    b.lastChange = millis();
    b.lastReading = reading;
  }
  if (millis() - b.lastChange > 30) {          // 30ms 安定したら確定
    if (reading != b.stableState) {
      b.stableState = reading;
      if (b.stableState == LOW) return true;   // HIGH→LOW＝押した瞬間
    }
  }
  return false;
}

void setup() {
  Serial.begin(115200);
  while (!Serial && millis() < 3000) { ; }     // Serial接続待ち（最大3秒、任意）

  pinMode(BUTTON_RECEIVE_PIN, INPUT_PULLUP);
  pinMode(BUTTON_SEND_PIN,    INPUT_PULLUP);

  IrReceiver.begin(IR_RECEIVE_PIN, ENABLE_LED_FEEDBACK);  // 受信開始
  IrSender.begin(IR_SEND_PIN);                            // 送信開始

  Serial.println(F("学習リモコン 準備完了"));
  Serial.println(F("受信ボタン(D4)で記録 / 送信ボタン(D5)で送信"));
}

void loop() {
  // ===== 受信ボタン：記録待ちにする =====
  if (wasPressed(btnReceive)) {
    armRecording = true;
    Serial.println(F("\n[受信モード] リモコンのボタンを押してください..."));
  }

  // ===== 赤外線の受信処理（常に監視） =====
  if (IrReceiver.decode()) {
    if (armRecording) {
      // リピート信号（押しっぱなし）は無視して、最初の1回だけ記録する
      if (!(IrReceiver.decodedIRData.flags & IRDATA_FLAGS_IS_REPEAT)) {
        if (IrReceiver.decodedIRData.protocol == UNKNOWN) {
          // プロトコル不明は write() で再送できないため記録しない
          Serial.println(F("  → プロトコル不明のため記録できません（生データ送信が必要）"));
        } else {
          storedIRData  = IrReceiver.decodedIRData;   // 構造体ごとコピーして保存
          hasStoredCode = true;
          armRecording  = false;
          Serial.print(F("  記録しました: "));
          IrReceiver.printIRResultShort(&Serial);     // 例: Protocol=NEC Address=0x.. Command=0x..
        }
      }
    }
    IrReceiver.resume();   // 次の受信に備える（毎回必須）
  }

  // ===== 送信ボタン：記録したコマンドを送る =====
  if (wasPressed(btnSend)) {
    if (hasStoredCode) {
      Serial.print(F("[送信] "));
      IrReceiver.printIRResultShort(&Serial);
      IrSender.write(&storedIRData);      // 保存したコマンドを送信
      IrReceiver.restartAfterSend();      // 送信で乱れた受信タイマを元に戻す
    } else {
      Serial.println(F("[送信] まだ記録がありません。先に受信ボタンで記録してください"));
    }
  }
}
